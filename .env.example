# Database
DATABASE_URL=postgresql://postgres:password@localhost:5433/scheduler?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=supersecretjwtkey
JWT_REFRESH_SECRET=supersecretrefreshkey

# Security
ENCRYPTION_KEY=32_byte_hex_string_for_aes_256_gcm

# Meta OAuth
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# AWS S3 (Production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=

# Server
PORT=3000
